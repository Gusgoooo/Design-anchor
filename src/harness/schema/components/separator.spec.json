{
  "id": "separator",
  "componentName": "Separator",
  "version": "1.0.0",
  "intent": "分隔线，用于视觉分隔内容区域；支持水平和垂直方向。",
  "wraps": {
    "module": "@/components/starter/separator",
    "primitives": ["Separator"]
  },
  "requiredProps": [],
  "optionalProps": [
    {
      "name": "orientation",
      "description": "分隔线方向",
      "type": "\"horizontal\" | \"vertical\"",
      "required": false,
      "defaultValue": "horizontal"
    },
    {
      "name": "decorative",
      "description": "是否仅为装饰性（不向无障碍树暴露 separator 角色）",
      "type": "boolean",
      "required": false,
      "defaultValue": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "shrink-0",
      "bg-border"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖分隔线颜色",
        "pattern": "^bg-"
      },
      {
        "description": "禁止覆盖尺寸（由 orientation 决定）",
        "pattern": "^(h-|w-)"
      }
    ]
  },
  "aiPrompt": "内容区域之间需要视觉分隔时使用 Separator；通过 orientation 控制方向；禁止用 <hr> 或手写 border 代替。",
  "meta": {
    "tags": ["separator", "divider", "line"],
    "category": "layout",
    "status": "stable"
  }
}
