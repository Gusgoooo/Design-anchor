{
  "id": "dialog",
  "componentName": "Dialog",
  "version": "1.0.0",
  "intent": "模态对话框，用于需要用户确认或输入信息的场景；阻断背景交互，支持受控与非受控模式。",
  "wraps": {
    "module": "@/components/starter/dialog",
    "primitives": ["Dialog", "DialogTrigger", "DialogContent", "DialogHeader", "DialogFooter", "DialogTitle", "DialogDescription", "DialogClose"]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "对话框内容结构",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "open",
      "description": "受控模式下的打开状态",
      "type": "boolean",
      "required": false
    },
    {
      "name": "onOpenChange",
      "description": "打开/关闭状态变更回调",
      "type": "(open: boolean) => void",
      "required": false
    },
    {
      "name": "defaultOpen",
      "description": "非受控模式下的初始状态",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "fixed",
      "inset-0",
      "z-50",
      "backdrop:bg-black/40",
      "max-w-lg",
      "rounded-lg",
      "border",
      "border-border",
      "bg-background",
      "shadow-lg"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖对话框定位与层级",
        "pattern": "^(fixed|absolute|z-)"
      },
      {
        "description": "禁止覆盖最大宽度（由 DialogContent 内部控制）",
        "pattern": "^max-w-"
      },
      {
        "description": "禁止覆盖背景色与边框",
        "pattern": "^(bg|border)-(background|border|card)"
      }
    ]
  },
  "aiPrompt": "需要模态交互时使用 Dialog 组件；结构为 Dialog > DialogTrigger + DialogContent > DialogHeader/DialogFooter；通过 open/onOpenChange 实现受控，或使用 DialogTrigger/DialogClose 实现非受控。",
  "meta": {
    "tags": ["dialog", "modal", "overlay", "popup"],
    "category": "overlay",
    "status": "stable"
  }
}
