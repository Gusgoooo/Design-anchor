{
  "id": "radio-group",
  "componentName": "RadioGroup",
  "version": "1.0.0",
  "intent": "单选按钮组，用于在多个互斥选项中选择一个；支持受控与非受控模式。",
  "wraps": {
    "module": "@/components/starter/radio-group",
    "primitives": ["RadioGroup", "RadioGroupItem"]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "RadioGroupItem 选项列表",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "defaultValue",
      "description": "非受控模式默认选中值",
      "type": "string",
      "required": false
    },
    {
      "name": "value",
      "description": "受控模式选中值",
      "type": "string",
      "required": false
    },
    {
      "name": "onValueChange",
      "description": "选中值变更回调",
      "type": "(value: string) => void",
      "required": false
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "grid",
      "aspect-square",
      "h-4",
      "w-4",
      "rounded-full",
      "border",
      "border-input",
      "bg-background"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖单选按钮尺寸",
        "pattern": "^(h-|w-)[0-9]"
      },
      {
        "description": "禁止覆盖圆角（必须保持圆形）",
        "pattern": "^rounded"
      }
    ]
  },
  "aiPrompt": "互斥选项选择使用 RadioGroup + RadioGroupItem；通过 value/onValueChange 实现受控；每个 RadioGroupItem 需搭配 Label 使用以保证无障碍。",
  "meta": {
    "tags": ["radio", "form", "selection", "group"],
    "category": "form",
    "status": "stable"
  }
}
