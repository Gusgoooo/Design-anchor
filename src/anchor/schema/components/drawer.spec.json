{
  "id": "drawer",
  "componentName": "Drawer",
  "version": "1.0.0",
  "intent": "Bottom/side drawer panel for mobile action sheets or auxiliary content display.",
  "wraps": {
    "module": "@/components/base/drawer",
    "primitives": [
      "Drawer",
      "DrawerPortal",
      "DrawerOverlay",
      "DrawerTrigger",
      "DrawerClose",
      "DrawerContent",
      "DrawerHeader",
      "DrawerFooter",
      "DrawerTitle",
      "DrawerDescription"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children content",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "fixed",
      "inset-x-0",
      "bottom-0",
      "z-50",
      "mt-8",
      "flex",
      "h-auto",
      "flex-col",
      "border",
      "bg-background"
    ],
    "blacklist": [
      {
        "description": "Do not override z-index positioning",
        "pattern": "^(z-|fixed|absolute|inset)"
      },
      {
        "description": "Do not override animations (controlled internally)",
        "pattern": "^(animate-|transition-|duration-)"
      }
    ]
  },
  "aiPrompt": "Use Drawer from @/components/base. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "drawer",
      "overlay"
    ],
    "category": "overlay",
    "status": "stable"
  }
}
