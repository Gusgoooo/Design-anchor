{
  "$comment": "Read by accord-audit.mjs; paths are matched as absolute path substrings relative to repo root",
  "scanRoots": ["src"],
  "excludePathSubstrings": [
    "/node_modules/",
    "/components/ui/",
    "/components/starter/",
    "/accord/schema/",
    "/design-portal/",
    "/design-tokens/",
    "/stories/",
    ".stories.",
    ".spec.json",
    "/__fixtures__/"
  ],
  "reportForbiddenHtmlFromSpecs": true,
  "flagArbitraryTailwind": true
}
