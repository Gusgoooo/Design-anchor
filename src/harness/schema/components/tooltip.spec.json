{
  "id": "tooltip",
  "componentName": "Tooltip",
  "version": "1.0.0",
  "intent": "文字提示气泡，用于鼠标悬停时展示辅助说明文字；不承载交互内容。",
  "wraps": {
    "module": "@/components/starter/tooltip",
    "primitives": ["TooltipProvider", "Tooltip", "TooltipTrigger", "TooltipContent"]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "提示结构（TooltipTrigger + TooltipContent）",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [],
  "styleLock": {
    "baselineTokens": [
      "absolute",
      "z-50",
      "rounded-md",
      "border",
      "border-border",
      "bg-popover",
      "text-xs",
      "text-popover-foreground",
      "shadow-md"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖定位与层级",
        "pattern": "^(absolute|fixed|z-)"
      },
      {
        "description": "禁止覆盖背景与文字色",
        "pattern": "^(bg|text)-(popover|foreground)"
      },
      {
        "description": "禁止覆盖字体大小",
        "pattern": "^text-(xs|sm|base|lg)"
      }
    ]
  },
  "aiPrompt": "需要悬停提示时使用 Tooltip 组件；结构为 TooltipProvider > Tooltip > TooltipTrigger + TooltipContent；内容仅限纯文字说明，交互内容请用 Popover。",
  "meta": {
    "tags": ["tooltip", "hint", "hover", "help"],
    "category": "overlay",
    "status": "stable"
  }
}
