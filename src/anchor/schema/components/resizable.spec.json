{
  "id": "resizable",
  "componentName": "Resizable",
  "version": "1.0.0",
  "intent": "Draggable resizable panel group for IDE-style multi-panel layouts.",
  "wraps": {
    "module": "@/components/base/resizable",
    "primitives": [
      "ResizablePanelGroup",
      "ResizablePanel",
      "ResizableHandle"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children content",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "h-full",
      "w-full"
    ],
    "blacklist": [
      {
        "description": "Do not override overflow and positioning",
        "pattern": "^(overflow|position|relative|absolute)"
      }
    ]
  },
  "aiPrompt": "Use Resizable from @/components/base. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "resizable",
      "layout"
    ],
    "category": "layout",
    "status": "stable"
  }
}
