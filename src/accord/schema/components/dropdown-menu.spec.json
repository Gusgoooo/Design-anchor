{
  "id": "dropdown-menu",
  "componentName": "DropdownMenu",
  "version": "1.0.0",
  "intent": "Dropdown menu for action lists below a trigger button. For 'more actions', bulk operations, etc.",
  "wraps": {
    "module": "@/components/starter/dropdown-menu",
    "primitives": [
      "DropdownMenu",
      "DropdownMenuTrigger",
      "DropdownMenuContent",
      "DropdownMenuItem",
      "DropdownMenuSeparator"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children prop",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [],
  "styleLock": {
    "baselineTokens": [
      "absolute",
      "z-50",
      "min-w-[10rem]",
      "rounded-md",
      "border",
      "border-border",
      "bg-popover",
      "text-popover-foreground",
      "shadow-md"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(absolute|fixed|z-)",
        "pattern": "^(absolute|fixed|z-)"
      },
      {
        "description": "Do not override styles matching pattern ^(bg|border)-(popover|border)",
        "pattern": "^(bg|border)-(popover|border)"
      },
      {
        "description": "Do not override styles matching pattern ^(rounded|shadow)",
        "pattern": "^(rounded|shadow)"
      }
    ]
  },
  "aiPrompt": "Use DropdownMenu from @/components/starter. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "dropdown",
      "menu",
      "action",
      "context-menu"
    ],
    "category": "overlay",
    "status": "stable"
  }
}
