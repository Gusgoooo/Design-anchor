{
  "id": "separator",
  "componentName": "Separator",
  "version": "1.0.0",
  "intent": "Visual separator between content areas. Supports horizontal and vertical directions.",
  "wraps": {
    "module": "@/components/starter/separator",
    "primitives": [
      "Separator"
    ]
  },
  "requiredProps": [],
  "optionalProps": [
    {
      "name": "orientation",
      "description": "Orientation prop",
      "type": "\"horizontal\" | \"vertical\"",
      "required": false,
      "defaultValue": "horizontal"
    },
    {
      "name": "decorative",
      "description": "Decorative prop",
      "type": "boolean",
      "required": false,
      "defaultValue": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "shrink-0",
      "bg-border"
    ],
    "blacklist": [
      {
        "description": "Do not override separator color",
        "pattern": "^bg-"
      },
      {
        "description": "Do not override styles matching pattern ^(h-|w-)",
        "pattern": "^(h-|w-)"
      }
    ]
  },
  "aiPrompt": "Use Separator from @/components/starter. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "separator",
      "divider",
      "line"
    ],
    "category": "layout",
    "status": "stable"
  }
}
