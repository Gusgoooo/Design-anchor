{
  "id": "breadcrumb",
  "componentName": "Breadcrumb",
  "version": "1.0.0",
  "intent": "Hierarchical breadcrumb navigation showing current page position in site structure with back navigation.",
  "wraps": {
    "module": "@/components/base/breadcrumb",
    "primitives": [
      "Breadcrumb",
      "BreadcrumbList",
      "BreadcrumbItem",
      "BreadcrumbLink",
      "BreadcrumbPage",
      "BreadcrumbSeparator",
      "BreadcrumbEllipsis"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children content",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "flex-wrap",
      "items-center",
      "gap-2",
      "break-words",
      "text-sm",
      "text-muted-foreground"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(flex|grid|gap-|items-|justify-)",
        "pattern": "^(flex|grid|gap-|items-|justify-)"
      }
    ]
  },
  "aiPrompt": "Use Breadcrumb from @/components/base for showing the current location inside a navigable hierarchy. Structure: Breadcrumb > BreadcrumbList > (BreadcrumbItem > BreadcrumbLink/Page) [+ BreadcrumbSeparator between each]. The current page should be a BreadcrumbPage (no link). Use BreadcrumbEllipsis when the path is long enough to need collapsing. Skip for single-level pages — breadcrumbs add noise when there's no hierarchy.",
  "examples": [
    {
      "title": "Standard 3-level breadcrumb",
      "snippet": "<Breadcrumb>\n  <BreadcrumbList>\n    <BreadcrumbItem><BreadcrumbLink href=\"/\">Home</BreadcrumbLink></BreadcrumbItem>\n    <BreadcrumbSeparator />\n    <BreadcrumbItem><BreadcrumbLink href=\"/components\">Components</BreadcrumbLink></BreadcrumbItem>\n    <BreadcrumbSeparator />\n    <BreadcrumbItem><BreadcrumbPage>Button</BreadcrumbPage></BreadcrumbItem>\n  </BreadcrumbList>\n</Breadcrumb>"
    },
    {
      "title": "Collapsed path with ellipsis",
      "snippet": "<Breadcrumb>\n  <BreadcrumbList>\n    <BreadcrumbItem><BreadcrumbLink href=\"/\">Home</BreadcrumbLink></BreadcrumbItem>\n    <BreadcrumbSeparator />\n    <BreadcrumbItem><BreadcrumbEllipsis /></BreadcrumbItem>\n    <BreadcrumbSeparator />\n    <BreadcrumbItem><BreadcrumbPage>Settings</BreadcrumbPage></BreadcrumbItem>\n  </BreadcrumbList>\n</Breadcrumb>"
    }
  ],
  "meta": {
    "tags": [
      "breadcrumb",
      "navigation"
    ],
    "category": "navigation",
    "status": "stable"
  }
}
