{
  "id": "tabs",
  "componentName": "Tabs",
  "version": "1.0.0",
  "intent": "Tab component for switching between views/panels in the same area. Supports controlled and uncontrolled modes.",
  "wraps": {
    "module": "@/components/starter/tabs",
    "primitives": [
      "Tabs",
      "TabsList",
      "TabsTrigger",
      "TabsContent"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children prop",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "defaultValue",
      "description": "Default Value prop",
      "type": "string",
      "required": false
    },
    {
      "name": "value",
      "description": "Value prop",
      "type": "string",
      "required": false
    },
    {
      "name": "onValueChange",
      "description": "On Value Change prop",
      "type": "(value: string) => void",
      "required": false
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "inline-flex",
      "items-center",
      "rounded-md",
      "bg-muted",
      "text-muted-foreground",
      "whitespace-nowrap",
      "text-sm",
      "ring-offset-background",
      "transition-all"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^bg-(muted|background|primary|secondary)",
        "pattern": "^bg-(muted|background|primary|secondary)"
      },
      {
        "description": "Do not override styles matching pattern ^rounded",
        "pattern": "^rounded"
      },
      {
        "description": "Do not override styles matching pattern ^(h-|p-|px-|py-)",
        "pattern": "^(h-|p-|px-|py-)"
      }
    ]
  },
  "aiPrompt": "Use Tabs from @/components/starter. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "tabs",
      "navigation",
      "panel",
      "view"
    ],
    "category": "navigation",
    "status": "stable"
  }
}
