{
  "id": "breadcrumb",
  "componentName": "Breadcrumb",
  "version": "1.0.0",
  "intent": "Hierarchical breadcrumb navigation showing current page position in site structure with back navigation.",
  "wraps": {
    "module": "@/components/base/breadcrumb",
    "primitives": [
      "Breadcrumb",
      "BreadcrumbList",
      "BreadcrumbItem",
      "BreadcrumbLink",
      "BreadcrumbPage",
      "BreadcrumbSeparator",
      "BreadcrumbEllipsis"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children content",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "flex-wrap",
      "items-center",
      "gap-2",
      "break-words",
      "text-sm",
      "text-muted-foreground"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(flex|grid|gap-|items-|justify-)",
        "pattern": "^(flex|grid|gap-|items-|justify-)"
      }
    ]
  },
  "aiPrompt": "Use Breadcrumb from @/components/base. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "breadcrumb",
      "navigation"
    ],
    "category": "navigation",
    "status": "stable"
  }
}
