{
  "id": "input-group",
  "componentName": "InputGroup",
  "version": "1.0.0",
  "intent": "Input group container combining prefix/suffix (icons, text, buttons) with input as a visual unit.",
  "wraps": {
    "module": "@/components/base/input-group",
    "primitives": [
      "InputGroup",
      "InputGroupAddon",
      "InputGroupButton",
      "InputGroupText",
      "InputGroupInput",
      "InputGroupTextarea"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children content",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "size",
      "description": "Size prop",
      "type": "\"xs\" | \"sm\"",
      "required": false,
      "defaultValue": "xs",
      "enumMap": {
        "xs": [
          "h-6",
          "gap-1",
          "rounded-[calc(var(--radius)-5px)]",
          "px-2",
          "has-[>svg]:px-2",
          "[&>svg:not([class*="
        ],
        "sm": [
          "h-8",
          "gap-2",
          "rounded-md",
          "px-3",
          "has-[>svg]:px-3"
        ]
      }
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "border-input",
      "shadow-xs",
      "relative",
      "flex",
      "w-full",
      "min-h-9",
      "items-stretch",
      "overflow-hidden",
      "rounded-md",
      "border",
      "outline-none"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(ring-|outline-)",
        "pattern": "^(ring-|outline-)"
      },
      {
        "description": "Do not override styles matching pattern ^h-",
        "pattern": "^h-"
      }
    ]
  },
  "aiPrompt": "Use InputGroup from @/components/base. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "input-group",
      "input"
    ],
    "category": "input",
    "status": "stable"
  }
}
