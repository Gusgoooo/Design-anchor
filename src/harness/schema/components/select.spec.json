{
  "id": "select",
  "componentName": "Select",
  "version": "1.0.0",
  "intent": "原生下拉选择器，统一边框与交互样式；用于简单选项场景，复杂异步选项请外层封装。",
  "wraps": {
    "module": "@/components/starter/select",
    "primitives": ["Select"]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "option 选项列表",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "disabled",
      "description": "禁用状态",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "w-full",
      "rounded-md",
      "border",
      "border-input",
      "bg-background",
      "text-sm",
      "shadow-sm",
      "transition-colors",
      "focus-visible:outline-none",
      "focus-visible:ring-1",
      "focus-visible:ring-ring",
      "disabled:cursor-not-allowed",
      "disabled:opacity-50"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖高度与内边距",
        "pattern": "^(h-|px-|py-|p-)"
      },
      {
        "description": "禁止覆盖圆角",
        "pattern": "^rounded"
      },
      {
        "description": "禁止覆盖边框与背景色",
        "pattern": "^(bg|border)-(input|background|primary)"
      }
    ]
  },
  "aiPrompt": "简单选择场景使用 Select 组件包裹 <option>；禁止在业务页使用裸 <select> 标签；复杂选择器（搜索、多选）需在此基础上封装。",
  "meta": {
    "tags": ["select", "form", "dropdown", "picker"],
    "category": "form",
    "status": "stable"
  }
}
