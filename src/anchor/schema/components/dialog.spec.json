{
  "id": "dialog",
  "componentName": "Dialog",
  "version": "1.0.0",
  "intent": "Modal dialog for user confirmation or input. Blocks background interaction, supports controlled and uncontrolled modes.",
  "wraps": {
    "module": "@/components/starter/dialog",
    "primitives": [
      "Dialog",
      "DialogTrigger",
      "DialogContent",
      "DialogHeader",
      "DialogFooter",
      "DialogTitle",
      "DialogDescription",
      "DialogClose"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children prop",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "open",
      "description": "Open prop",
      "type": "boolean",
      "required": false
    },
    {
      "name": "onOpenChange",
      "description": "On Open Change prop",
      "type": "(open: boolean) => void",
      "required": false
    },
    {
      "name": "defaultOpen",
      "description": "Default Open prop",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "fixed",
      "inset-0",
      "z-50",
      "backdrop:bg-black/40",
      "max-w-lg",
      "rounded-lg",
      "border",
      "border-border",
      "bg-background",
      "shadow-lg"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(fixed|absolute|z-)",
        "pattern": "^(fixed|absolute|z-)"
      },
      {
        "description": "Do not override styles matching pattern ^max-w-",
        "pattern": "^max-w-"
      },
      {
        "description": "Do not override styles matching pattern ^(bg|border)-(background|border|card)",
        "pattern": "^(bg|border)-(background|border|card)"
      }
    ]
  },
  "aiPrompt": "Use Dialog from @/components/starter. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "dialog",
      "modal",
      "overlay",
      "popup"
    ],
    "category": "overlay",
    "status": "stable"
  }
}
