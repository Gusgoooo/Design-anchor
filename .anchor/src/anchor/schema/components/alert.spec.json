{
  "id": "alert",
  "componentName": "Alert",
  "version": "1.0.0",
  "intent": "Displays important status feedback (success, warning, error) with optional title and description.",
  "wraps": {
    "module": "@/components/starter/alert",
    "primitives": [
      "Alert",
      "AlertTitle",
      "AlertDescription"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Alert content (typically AlertTitle + AlertDescription)",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "variant",
      "description": "Visual variant",
      "type": "\"default\" | \"destructive\"",
      "required": false,
      "defaultValue": "default",
      "enumMap": {
        "default": [
          "border-border",
          "bg-background",
          "text-foreground"
        ],
        "destructive": [
          "border-destructive/50",
          "text-destructive"
        ]
      }
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "relative",
      "w-full",
      "rounded-lg",
      "border",
      "px-4",
      "text-sm"
    ],
    "blacklist": [
      {
        "description": "Do not override padding and border-radius",
        "pattern": "^(p-|px-|py-|rounded)"
      },
      {
        "description": "Do not override semantic colors (controlled by variant)",
        "pattern": "^(bg|text|border)-(primary|secondary|destructive|accent)"
      }
    ]
  },
  "aiPrompt": "Use Alert from @/components/starter. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "alert",
      "notification",
      "feedback"
    ],
    "category": "feedback",
    "status": "stable"
  }
}
