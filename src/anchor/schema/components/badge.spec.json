{
  "id": "badge",
  "componentName": "Badge",
  "version": "1.0.0",
  "intent": "Unified entry for status marks, labels, and count bubbles. Do not hand-build span+bg alternatives.",
  "wraps": {
    "module": "@/components/base/badge",
    "primitives": [
      "Badge"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children prop",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "variant",
      "description": "Visual variant",
      "type": "\"default\" | \"secondary\" | \"destructive\" | \"outline\"",
      "required": false,
      "defaultValue": "default",
      "enumMap": {
        "default": [
          "border-transparent",
          "bg-primary",
          "text-primary-foreground",
          "shadow"
        ],
        "secondary": [
          "border-transparent",
          "bg-secondary",
          "text-secondary-foreground"
        ],
        "destructive": [
          "border-transparent",
          "bg-destructive",
          "text-destructive-foreground",
          "shadow"
        ],
        "outline": [
          "text-foreground"
        ]
      }
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "inline-flex",
      "items-center",
      "rounded-md",
      "border",
      "px-2",
      "py-0.5",
      "text-xs",
      "font-semibold",
      "transition-colors"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(px-|py-|p-|pt-|pb-|pl-|pr-)",
        "pattern": "^(px-|py-|p-|pt-|pb-|pl-|pr-)"
      },
      {
        "description": "Do not override styles matching pattern ^(border|rounded)",
        "pattern": "^(border|rounded)"
      },
      {
        "description": "Do not override brand/semantic colors (mapped by variant)",
        "pattern": "^(bg|text)-(primary|secondary|destructive|accent|muted)"
      },
      {
        "description": "Do not use arbitrary spacing values",
        "pattern": "^(m|p|gap)-\\["
      }
    ]
  },
  "aiPrompt": "Use Badge from @/components/base for status labels, count chips, and inline tags. Pick variant by intent: default=primary highlight, secondary=neutral marker, destructive=error/warning state, outline=quiet emphasis. Don't hand-roll `<span className=\"px-2 py-0.5 bg-blue-100 text-blue-700 rounded\">` — it bypasses the variant contract and ages into visual drift.",
  "examples": [
    {
      "title": "Status variants",
      "snippet": "<div className=\"flex gap-2\">\n  <Badge>Active</Badge>\n  <Badge variant=\"secondary\">Draft</Badge>\n  <Badge variant=\"destructive\">Expired</Badge>\n  <Badge variant=\"outline\">Optional</Badge>\n</div>"
    },
    {
      "title": "Count bubble next to a label",
      "snippet": "<span className=\"inline-flex items-center gap-2\">\n  Notifications\n  <Badge variant=\"secondary\">12</Badge>\n</span>"
    },
    {
      "title": "Inline tags in a list item",
      "snippet": "<Item>\n  <ItemContent>\n    <ItemTitle>Q4 roadmap</ItemTitle>\n    <ItemDescription>\n      <Badge variant=\"outline\">draft</Badge> <Badge>in review</Badge>\n    </ItemDescription>\n  </ItemContent>\n</Item>"
    }
  ],
  "forbidden": [],
  "corrections": [],
  "referencePriority": [
    "@/components/base/badge",
    "@/components/base"
  ],
  "meta": {
    "tags": [
      "badge",
      "tag",
      "label",
      "status"
    ],
    "category": "data-display",
    "status": "stable"
  }
}
