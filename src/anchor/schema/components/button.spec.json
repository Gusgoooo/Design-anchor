{
  "id": "button",
  "componentName": "Button",
  "version": "1.0.0",
  "intent": "Unified clickable action entry for primary, secondary, and link navigation actions. Raw <button> with manual spacing and brand colors is forbidden.",
  "wraps": {
    "module": "@/components/base/button",
    "primitives": [
      "Button"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Button label or icon",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "variant",
      "description": "Visual variant",
      "type": "\"default\" | \"destructive\" | \"outline\" | \"secondary\" | \"ghost\" | \"link\"",
      "required": false,
      "defaultValue": "default",
      "enumMap": {
        "default": [
          "bg-primary",
          "text-primary-foreground",
          "shadow",
          "hover:bg-primary/90"
        ],
        "destructive": [
          "bg-destructive",
          "text-destructive-foreground",
          "shadow-sm",
          "hover:bg-destructive/90"
        ],
        "outline": [
          "border",
          "border-input",
          "bg-background",
          "shadow-sm",
          "hover:bg-accent",
          "hover:text-accent-foreground"
        ],
        "secondary": [
          "bg-secondary",
          "text-secondary-foreground",
          "shadow-sm",
          "hover:bg-secondary/80"
        ],
        "ghost": [
          "hover:bg-accent",
          "hover:text-accent-foreground"
        ],
        "link": [
          "text-primary",
          "underline-offset-4",
          "hover:underline"
        ]
      }
    },
    {
      "name": "size",
      "description": "Size",
      "type": "\"default\" | \"sm\" | \"lg\" | \"icon\"",
      "required": false,
      "defaultValue": "default",
      "enumMap": {
        "default": [
          "h-9",
          "px-4",
          "py-2",
          "text-sm"
        ],
        "sm": [
          "h-7",
          "px-3",
          "text-xs"
        ],
        "lg": [
          "h-11",
          "px-8",
          "text-sm"
        ],
        "icon": [
          "size-9",
          "shrink-0",
          "p-0"
        ]
      }
    },
    {
      "name": "disabled",
      "description": "Disabled state",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "inline-flex",
      "items-center",
      "justify-center",
      "rounded-md",
      "text-sm",
      "font-medium",
      "transition-colors",
      "focus-visible:outline-none",
      "focus-visible:ring-1",
      "focus-visible:ring-ring",
      "disabled:pointer-events-none",
      "disabled:opacity-50"
    ],
    "blacklist": [
      {
        "description": "Do not override button height and padding (mapped by size)",
        "pattern": "^(h-|px-|py-|p-|pt-|pb-|pl-|pr-)"
      },
      {
        "description": "Do not override border-radius (driven by design token --radius)",
        "pattern": "^rounded"
      },
      {
        "description": "Do not override brand/semantic colors (mapped by variant)",
        "pattern": "^(bg|text|border)-(primary|secondary|destructive|accent|muted)"
      },
      {
        "description": "Do not use arbitrary spacing values",
        "pattern": "^(m|p|gap|space-[xy])-\\["
      }
    ]
  },
  "aiPrompt": "Always use Button from @/components/base/button — never raw <button>. Pick variant by intent: default=primary CTA, secondary=neutral action, outline=secondary CTA on a busy surface, ghost=low-emphasis (toolbar / row action), link=inline text action, destructive=delete/cancel. Pick size by context: default=most use, sm=table rows / tight toolbars, lg=hero CTAs, icon=icon-only square. Use asChild to render as another element (e.g., a Next.js Link) while keeping all Button styles. Don't stack `className=\"bg-blue-500 text-white px-3\"` — that bypasses variant + size and causes drift.",
  "examples": [
    {
      "title": "Primary CTA",
      "snippet": "<Button onClick={onSubmit}>Save changes</Button>"
    },
    {
      "title": "Variants side-by-side",
      "snippet": "<div className=\"flex gap-2\">\n  <Button>Default</Button>\n  <Button variant=\"secondary\">Secondary</Button>\n  <Button variant=\"outline\">Outline</Button>\n  <Button variant=\"ghost\">Ghost</Button>\n  <Button variant=\"destructive\">Delete</Button>\n</div>"
    },
    {
      "title": "Icon-only button",
      "snippet": "<Button variant=\"ghost\" size=\"icon\" aria-label=\"Settings\">\n  <SettingsIcon />\n</Button>"
    },
    {
      "title": "asChild — render as a Link",
      "snippet": "<Button asChild variant=\"outline\">\n  <a href=\"/docs\">Read docs</a>\n</Button>"
    }
  ],
  "forbidden": [
    {
      "htmlTag": "button",
      "reason": "Raw <button> is forbidden to ensure consistent border-radius, spacing, and brand colors",
      "useInstead": "@/components/base/button"
    }
  ],
  "corrections": [
    {
      "id": "no-raw-button",
      "violation": "Using raw native  <button>",
      "fixPrompt": "Replace with  import { Button } from '@/components/base/Button', Use variant and size props for styling. "
    }
  ],
  "referencePriority": [
    "@/components/base/button",
    "@/components/base"
  ],
  "meta": {
    "tags": [
      "button",
      "action",
      "cta"
    ],
    "category": "action",
    "status": "stable"
  }
}
