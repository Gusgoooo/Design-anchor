{
  "id": "tooltip",
  "componentName": "Tooltip",
  "version": "1.0.0",
  "intent": "Text tooltip bubble showing helper text on hover. Must not contain interactive content.",
  "wraps": {
    "module": "@/components/base/tooltip",
    "primitives": [
      "TooltipProvider",
      "Tooltip",
      "TooltipTrigger",
      "TooltipPortal",
      "TooltipArrow",
      "TooltipContent"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children prop",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [],
  "styleLock": {
    "baselineTokens": [
      "absolute",
      "z-50",
      "rounded-md",
      "border",
      "border-border",
      "bg-popover",
      "text-xs",
      "text-popover-foreground",
      "shadow-md"
    ],
    "blacklist": [
      {
        "description": "Do not override positioning and z-index",
        "pattern": "^(absolute|fixed|z-)"
      },
      {
        "description": "Do not override styles matching pattern ^(bg|text)-(popover|foreground)",
        "pattern": "^(bg|text)-(popover|foreground)"
      },
      {
        "description": "Do not override styles matching pattern ^text-(xs|sm|base|lg)",
        "pattern": "^text-(xs|sm|base|lg)"
      }
    ]
  },
  "aiPrompt": "Use Tooltip from @/components/base. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "tooltip",
      "hint",
      "hover",
      "help"
    ],
    "category": "overlay",
    "status": "stable"
  }
}
