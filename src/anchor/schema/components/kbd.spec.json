{
  "id": "kbd",
  "componentName": "Kbd",
  "version": "1.0.0",
  "intent": "Keyboard shortcut label displaying key combinations (e.g., Ctrl+S) with visual styling.",
  "wraps": {
    "module": "@/components/base/kbd",
    "primitives": [
      "Kbd",
      "KbdGroup"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children content",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "bg-muted",
      "text-muted-foreground",
      "pointer-events-none",
      "inline-flex",
      "h-5",
      "w-fit",
      "min-w-5",
      "select-none",
      "items-center",
      "justify-center",
      "gap-1",
      "rounded-sm"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(font-family|font-mono|font-sans)",
        "pattern": "^(font-family|font-mono|font-sans)"
      }
    ]
  },
  "aiPrompt": "Use Kbd from @/components/base. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "kbd",
      "typography"
    ],
    "category": "typography",
    "status": "stable"
  }
}
