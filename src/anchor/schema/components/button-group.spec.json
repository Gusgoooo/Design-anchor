{
  "id": "button-group",
  "componentName": "ButtonGroup",
  "version": "1.0.0",
  "intent": "Button group container that visually combines related action buttons (toolbars, segmented controls).",
  "wraps": {
    "module": "@/components/base/button-group",
    "primitives": [
      "ButtonGroup",
      "ButtonGroupSeparator",
      "ButtonGroupText"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children content",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "bg-muted",
      "shadow-xs",
      "flex",
      "items-center",
      "gap-2",
      "rounded-md",
      "border",
      "px-4",
      "text-sm",
      "font-medium"
    ],
    "blacklist": [
      {
        "description": "Do not override overflow and positioning",
        "pattern": "^(overflow|position|relative|absolute)"
      }
    ]
  },
  "aiPrompt": "Use ButtonGroup from @/components/base. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "button-group",
      "layout"
    ],
    "category": "layout",
    "status": "stable"
  }
}
