{
  "id": "avatar",
  "componentName": "Avatar",
  "version": "1.0.0",
  "intent": "User avatar with image loading and text fallback. Used in user lists, comments, and navigation bars.",
  "wraps": {
    "module": "@/components/base/avatar",
    "primitives": [
      "Avatar",
      "AvatarImage",
      "AvatarFallback"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children prop",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [],
  "styleLock": {
    "baselineTokens": [
      "relative",
      "flex",
      "h-10",
      "w-10",
      "shrink-0",
      "overflow-hidden",
      "rounded-full",
      "border",
      "border-border",
      "bg-muted"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(h-|w-)[0-9]",
        "pattern": "^(h-|w-)[0-9]"
      },
      {
        "description": "Do not override styles matching pattern ^rounded",
        "pattern": "^rounded"
      }
    ]
  },
  "aiPrompt": "Use Avatar from @/components/base for user / profile representations. Always pair AvatarImage with AvatarFallback — the fallback renders while the image loads and if it fails. Fallback should be initials (1–2 chars) or an icon, never long text. Avoid stacking `bg-*` arbitrary colors; the Radix Avatar primitive handles fallback styling.",
  "examples": [
    {
      "title": "Image with text fallback",
      "snippet": "<Avatar>\n  <AvatarImage src={user.avatarUrl} alt={user.name} />\n  <AvatarFallback>{user.initials}</AvatarFallback>\n</Avatar>"
    },
    {
      "title": "Fallback only — initials",
      "snippet": "<Avatar>\n  <AvatarFallback>SC</AvatarFallback>\n</Avatar>"
    },
    {
      "title": "Stacked avatar group",
      "snippet": "<div className=\"flex -space-x-2\">\n  {team.map((u) => (\n    <Avatar key={u.id} className=\"ring-2 ring-background\">\n      <AvatarImage src={u.avatarUrl} />\n      <AvatarFallback>{u.initials}</AvatarFallback>\n    </Avatar>\n  ))}\n</div>"
    }
  ],
  "meta": {
    "tags": [
      "avatar",
      "user",
      "profile",
      "image"
    ],
    "category": "data-display",
    "status": "stable"
  }
}
