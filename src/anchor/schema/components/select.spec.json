{
  "id": "select",
  "componentName": "Select",
  "version": "1.0.0",
  "intent": "Dropdown select with unified border and interaction styles. For simple options; wrap externally for async/complex cases.",
  "wraps": {
    "module": "@/components/base/select",
    "primitives": [
      "Select",
      "SelectGroup",
      "SelectValue",
      "SelectTrigger",
      "SelectContent",
      "SelectLabel",
      "SelectItem",
      "SelectSeparator",
      "SelectScrollUpButton",
      "SelectScrollDownButton",
      "SelectPortal",
      "SelectIcon",
      "SelectViewport",
      "SelectItemText",
      "SelectItemIndicator",
      "SelectArrow"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children prop",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "disabled",
      "description": "Disabled state",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    },
    {
      "name": "size",
      "description": "Size prop",
      "type": "\"sm\" | \"default\" | \"lg\"",
      "required": false,
      "defaultValue": "default"
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "h-7",
      "h-9",
      "h-11",
      "w-full",
      "rounded-md",
      "border",
      "border-input",
      "bg-background",
      "text-xs",
      "text-sm",
      "shadow-sm",
      "transition-colors",
      "focus-visible:outline-none",
      "focus-visible:ring-1",
      "focus-visible:ring-ring",
      "disabled:cursor-not-allowed",
      "disabled:opacity-50"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(h-|px-|py-|p-)",
        "pattern": "^(h-|px-|py-|p-)"
      },
      {
        "description": "Do not override styles matching pattern ^rounded",
        "pattern": "^rounded"
      },
      {
        "description": "Do not override styles matching pattern ^(bg|border)-(input|background|primary)",
        "pattern": "^(bg|border)-(input|background|primary)"
      }
    ]
  },
  "aiPrompt": "Use Select from @/components/base. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "select",
      "form",
      "dropdown",
      "picker"
    ],
    "category": "form",
    "status": "stable"
  }
}
