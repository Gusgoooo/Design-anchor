{
  "id": "checkbox",
  "componentName": "Checkbox",
  "version": "1.0.0",
  "intent": "Unified check/uncheck entry for form agreements, multi-select filters, and batch selection. Raw <input type=checkbox> is forbidden.",
  "wraps": {
    "module": "@/components/starter/checkbox",
    "primitives": [
      "Checkbox",
      "CheckboxIndicator"
    ]
  },
  "requiredProps": [],
  "optionalProps": [
    {
      "name": "disabled",
      "description": "Disabled state",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    },
    {
      "name": "defaultChecked",
      "description": "Default Checked prop",
      "type": "boolean | \"indeterminate\"",
      "required": false,
      "defaultValue": false
    },
    {
      "name": "checked",
      "description": "Controlled checked state; pass \"indeterminate\" for the mixed state.",
      "type": "boolean | \"indeterminate\"",
      "required": false
    },
    {
      "name": "size",
      "description": "Box + icon size",
      "type": "\"sm\" | \"default\" | \"lg\"",
      "required": false,
      "defaultValue": "default"
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "h-4",
      "w-4",
      "shrink-0",
      "rounded",
      "border",
      "border-input",
      "accent-primary"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(h-|w-|size-)",
        "pattern": "^(h-|w-|size-)"
      },
      {
        "description": "Do not override styles matching pattern ^(border|rounded)",
        "pattern": "^(border|rounded)"
      },
      {
        "description": "Do not override styles matching pattern ^accent-",
        "pattern": "^accent-"
      },
      {
        "description": "Do not use arbitrary spacing values",
        "pattern": "^(m|p|gap)-\\["
      }
    ]
  },
  "aiPrompt": "Must use @/components/starter/checkbox. Do not hand-write alternatives.",
  "forbidden": [],
  "corrections": [],
  "referencePriority": [
    "@/components/starter/checkbox",
    "@/components/starter"
  ],
  "meta": {
    "tags": [
      "checkbox",
      "toggle",
      "form"
    ],
    "category": "form",
    "status": "stable"
  }
}
