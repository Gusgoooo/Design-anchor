{
  "id": "spinner",
  "componentName": "Spinner",
  "version": "1.0.0",
  "intent": "Loading spinner indicator for in-button, area, or full-screen loading states.",
  "wraps": {
    "module": "@/components/starter/spinner",
    "primitives": [
      "Spinner"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children content",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "size-4",
      "animate-spin"
    ],
    "blacklist": [
      {
        "description": "Do not override animations",
        "pattern": "^(animate-|transition-)"
      }
    ]
  },
  "aiPrompt": "Use Spinner from @/components/starter. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "spinner",
      "feedback"
    ],
    "category": "feedback",
    "status": "stable"
  }
}
