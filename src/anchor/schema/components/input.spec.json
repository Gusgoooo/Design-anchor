{
  "id": "input",
  "componentName": "Input",
  "version": "1.0.0",
  "intent": "Unified text input entry for search, form fields, passwords, etc. Raw <input> with manual spacing and borders is forbidden.",
  "wraps": {
    "module": "@/components/starter/input",
    "primitives": [
      "Input"
    ]
  },
  "requiredProps": [],
  "optionalProps": [
    {
      "name": "type",
      "description": "Type prop",
      "type": "\"text\" | \"password\" | \"email\" | \"number\" | \"search\" | \"tel\" | \"url\"",
      "required": false,
      "defaultValue": "text"
    },
    {
      "name": "placeholder",
      "description": "Placeholder prop",
      "type": "string",
      "required": false
    },
    {
      "name": "disabled",
      "description": "Disabled state",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    },
    {
      "name": "size",
      "description": "Size prop",
      "type": "\"sm\" | \"default\" | \"lg\"",
      "required": false,
      "defaultValue": "default"
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "h-7",
      "h-9",
      "h-11",
      "w-full",
      "min-w-0",
      "rounded-md",
      "border",
      "border-input",
      "bg-transparent",
      "px-2.5",
      "px-3",
      "px-4",
      "py-0",
      "py-1",
      "py-1.5",
      "text-xs",
      "text-sm",
      "shadow-sm",
      "transition-colors"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(h-|px-|py-|p-|pt-|pb-|pl-|pr-)",
        "pattern": "^(h-|px-|py-|p-|pt-|pb-|pl-|pr-)"
      },
      {
        "description": "Do not override styles matching pattern ^(border|rounded|ring|outline)",
        "pattern": "^(border|rounded|ring|outline)"
      },
      {
        "description": "Do not use arbitrary spacing values",
        "pattern": "^(m|p|gap|space-[xy])-\\["
      }
    ]
  },
  "aiPrompt": "Must use @/components/starter/input. Do not stack Tailwind overrides on JSX.",
  "forbidden": [
    {
      "htmlTag": "input",
      "reason": "Raw <input> is forbidden to ensure consistent height, border, and focus styles",
      "useInstead": "@/components/starter/input"
    }
  ],
  "corrections": [
    {
      "id": "no-raw-input",
      "violation": "Using raw native  <input>",
      "fixPrompt": "Replace with  import { Input } from '@/components/starter/Input'. "
    }
  ],
  "referencePriority": [
    "@/components/starter/input",
    "@/components/starter"
  ],
  "meta": {
    "tags": [
      "input",
      "text-field",
      "form"
    ],
    "category": "form",
    "status": "stable"
  }
}
