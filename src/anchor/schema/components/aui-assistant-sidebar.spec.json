{
  "id": "aui-assistant-sidebar",
  "componentName": "AssistantSidebar",
  "version": "1.0.0",
  "intent": "Sidebar AI assistant layout. Splits page into main content and AI conversation sidebar with a draggable divider. For workspace scenarios needing AI assistance.",
  "wraps": {
    "module": "@/components/starter/ai/assistant-sidebar",
    "primitives": [
      "AssistantSidebar"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Main content area",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "optionalProps": [],
  "styleLock": {
    "baselineTokens": [
      "flex",
      "h-full",
      "w-full",
      "border",
      "bg-background"
    ],
    "blacklist": [
      {
        "description": "Do not override layout structure (flex split controlled internally)",
        "pattern": "^(flex|grid|gap-|items-|justify-)"
      },
      {
        "description": "Do not override separator and drag behavior",
        "pattern": "^(cursor|resize)"
      },
      {
        "description": "Do not override container height",
        "pattern": "^h-"
      }
    ]
  },
  "aiPrompt": "Use AssistantSidebar from @/components/starter. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "referencePriority": [
    "@/components/starter/ai/assistant-sidebar"
  ],
  "examples": [
    {
      "title": "Workspace Layout",
      "snippet": "<AssistantRuntimeProvider runtime={runtime}>\n  <AssistantSidebar>\n    <YourWorkspaceContent />\n  </AssistantSidebar>\n</AssistantRuntimeProvider>"
    }
  ],
  "meta": {
    "tags": [
      "sidebar",
      "panel",
      "split",
      "assistant",
      "ai"
    ],
    "category": "ai",
    "status": "stable"
  }
}
