{
  "$comment": "Read by anchor-audit.mjs; paths are matched as absolute path substrings relative to repo root",
  "scanRoots": ["src"],
  "excludePathSubstrings": [
    "/node_modules/",
    "/components/ui/",
    "/components/base/",
    "/anchor/schema/",
    "/anchor-portal/",
    "/design-portal/",
    "/design-tokens/",
    "/stories/",
    ".stories.",
    ".demo.",
    ".spec.json",
    "/__fixtures__/"
  ],
  "reportForbiddenHtmlFromSpecs": true,
  "flagArbitraryTailwind": true
}
