{
  "id": "progress",
  "componentName": "Progress",
  "version": "1.0.0",
  "intent": "进度条，用于展示任务完成百分比；支持自定义最大值与无障碍属性。",
  "wraps": {
    "module": "@/components/starter/progress",
    "primitives": ["Progress"]
  },
  "requiredProps": [],
  "optionalProps": [
    {
      "name": "value",
      "description": "当前进度值",
      "type": "number",
      "required": false,
      "defaultValue": 0
    },
    {
      "name": "max",
      "description": "最大值",
      "type": "number",
      "required": false,
      "defaultValue": 100
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "relative",
      "h-2",
      "w-full",
      "overflow-hidden",
      "rounded-full",
      "bg-secondary"
    ],
    "blacklist": [
      {
        "description": "禁止覆盖进度条高度与圆角",
        "pattern": "^(h-|rounded)"
      },
      {
        "description": "禁止覆盖轨道与填充颜色",
        "pattern": "^bg-(primary|secondary)"
      }
    ]
  },
  "aiPrompt": "展示进度时使用 Progress 组件；通过 value 和 max 控制进度；禁止手动设置 h-/bg- 覆盖样式。",
  "meta": {
    "tags": ["progress", "loading", "bar", "percentage"],
    "category": "feedback",
    "status": "stable"
  }
}
