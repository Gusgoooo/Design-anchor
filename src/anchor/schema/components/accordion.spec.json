{
  "id": "accordion",
  "componentName": "Accordion",
  "version": "1.0.0",
  "intent": "Collapsible content panels for FAQ, settings groups, and progressive disclosure.",
  "wraps": {
    "module": "@/components/starter/accordion",
    "primitives": [
      "Accordion",
      "AccordionItem",
      "AccordionHeader",
      "AccordionTrigger",
      "AccordionContent"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children content",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "border-b"
    ],
    "blacklist": [
      {
        "description": "Do not override transition animations",
        "pattern": "^(transition-|duration-|data-)"
      }
    ]
  },
  "aiPrompt": "Use Accordion from @/components/starter. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "accordion",
      "disclosure"
    ],
    "category": "disclosure",
    "status": "stable"
  }
}
