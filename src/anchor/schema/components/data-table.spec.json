{
  "id": "data-table",
  "componentName": "DataTable",
  "version": "1.0.0",
  "intent": "Primary business data table: pagination, sorting, bulk actions converge here. Raw <table> with arbitrary spacing is forbidden.",
  "wraps": {
    "module": "@/components/ui/table",
    "primitives": [
      "Table",
      "TableHeader",
      "TableBody",
      "TableRow",
      "TableHead",
      {
        "symbol": "TableCell",
        "displayName": "Data Cell (TableCell)"
      }
    ]
  },
  "requiredProps": [
    {
      "name": "columns",
      "description": "Columns prop",
      "type": "ColumnDef<T>[]",
      "required": true
    },
    {
      "name": "data",
      "description": "Data prop",
      "type": "T[]",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "density",
      "description": "Density prop",
      "type": "\"compact\" | \"comfortable\" | \"default\"",
      "required": false,
      "defaultValue": "default",
      "enumMap": {
        "compact": [
          "text-xs",
          "py-business-table-cell-y-compact",
          "px-3"
        ],
        "comfortable": [
          "text-sm",
          "py-business-table-cell-y-comfortable",
          "px-4"
        ],
        "default": [
          "text-sm",
          "py-business-table-cell-y-default",
          "px-3"
        ]
      }
    },
    {
      "name": "variant",
      "description": "Variant prop",
      "type": "\"plain\" | \"striped\"",
      "required": false,
      "defaultValue": "plain",
      "enumMap": {
        "plain": [],
        "striped": [
          "even:bg-muted/40"
        ]
      }
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "w-full",
      "caption-bottom",
      "text-sm",
      "border-collapse"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(p|px|py|pt|pb|pl|pr)-",
        "pattern": "^(p|px|py|pt|pb|pl|pr)-"
      },
      {
        "description": "Do not override styles matching pattern ^(border|rounded|ring|outline|divide)-",
        "pattern": "^(border|rounded|ring|outline|divide)-"
      },
      {
        "description": "Do not override styles matching pattern ^(bg|text|border)-(primary|secondary|destructive|accent|muted|card|popover)",
        "pattern": "^(bg|text|border)-(primary|secondary|destructive|accent|muted|card|popover)"
      },
      {
        "description": "Do not override styles matching pattern ^(m|p|gap|space-[xy])-\\[",
        "pattern": "^(m|p|gap|space-[xy])-\\["
      }
    ]
  },
  "aiPrompt": "Use DataTable from @/components/starter. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "forbidden": [
    {
      "htmlTag": "table",
      "reason": "Business lists must use DataTable to ensure consistent spacing and brand compliance",
      "useInstead": "@/components/starter/data-table"
    }
  ],
  "corrections": [
    {
      "id": "no-raw-table",
      "violation": "Using raw native  <table>",
      "fixPrompt": "Replace with the proper component import and use semantic props for styling."
    },
    {
      "id": "no-hacky-spacing",
      "violation": "Violation: using raw tag or hand-built alternative",
      "fixPrompt": "Replace with the proper component import and use semantic props for styling."
    }
  ],
  "referencePriority": [
    "@/components/starter/data-table",
    "@/components/starter"
  ],
  "tailwindExtend": {
    "spacing": {
      "business-table-cell-y-compact": "0.5rem",
      "business-table-cell-y-default": "0.75rem",
      "business-table-cell-y-comfortable": "1rem"
    }
  },
  "meta": {
    "tags": [
      "table",
      "list",
      "data-grid"
    ],
    "portalConfigFile": "data-table.spec.json"
  }
}
