{
  "id": "aui-model-selector",
  "componentName": "ModelSelector",
  "version": "1.0.0",
  "intent": "AI model selector dropdown. Lets users switch the current conversation's AI model with icons, descriptions, and disabled states.",
  "wraps": {
    "module": "@/components/starter/ai/model-selector",
    "primitives": [
      "ModelSelector",
      "ModelSelectorRoot",
      "ModelSelectorTrigger",
      "ModelSelectorContent",
      "ModelSelectorItem",
      "ModelSelectorValue"
    ]
  },
  "requiredProps": [
    {
      "name": "models",
      "description": "Available model list",
      "type": "ModelOption[]",
      "required": true
    }
  ],
  "optionalProps": [
    {
      "name": "variant",
      "description": "Trigger visual variant",
      "type": "\"outline\" | \"ghost\" | \"muted\"",
      "required": false,
      "defaultValue": "outline"
    },
    {
      "name": "size",
      "description": "Trigger size",
      "type": "\"sm\" | \"default\" | \"lg\"",
      "required": false,
      "defaultValue": "default"
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "rounded-md",
      "border",
      "text-sm",
      "bg-popover",
      "shadow-lg",
      "transition-colors"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(z-|fixed|absolute)",
        "pattern": "^(z-|fixed|absolute)"
      },
      {
        "description": "Do not override styles matching pattern ^(h-|px-|py-)",
        "pattern": "^(h-|px-|py-)"
      },
      {
        "description": "Do not override styles matching pattern ^(bg|border)-(popover|input|background)",
        "pattern": "^(bg|border)-(popover|input|background)"
      }
    ]
  },
  "aiPrompt": "Use ModelSelector from @/components/starter. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "referencePriority": [
    "@/components/starter/ai/model-selector"
  ],
  "examples": [
    {
      "title": "Simple Model Selector",
      "snippet": "const models = [\n  { id: \"gpt-4\", name: \"GPT-4\", description: \"Most capable\" },\n  { id: \"gpt-3.5\", name: \"GPT-3.5\", description: \"Fast\" },\n];\n\n<ModelSelector models={models} variant=\"outline\" />"
    },
    {
      "title": "Controlled Model Selector",
      "snippet": "<ModelSelector\n  models={models}\n  value={selectedModel}\n  onValueChange={setSelectedModel}\n  variant=\"ghost\"\n  size=\"sm\"\n/>"
    }
  ],
  "meta": {
    "tags": [
      "model",
      "selector",
      "dropdown",
      "ai"
    ],
    "category": "ai",
    "status": "stable"
  }
}
