{
  "id": "slider",
  "componentName": "Slider",
  "version": "1.0.0",
  "intent": "Slider control for selecting a value within a range. Based on native range input.",
  "wraps": {
    "module": "@/components/starter/slider",
    "primitives": [
      "Slider"
    ]
  },
  "requiredProps": [],
  "optionalProps": [
    {
      "name": "min",
      "description": "Min value",
      "type": "number",
      "required": false,
      "defaultValue": 0
    },
    {
      "name": "max",
      "description": "Max value",
      "type": "number",
      "required": false,
      "defaultValue": 100
    },
    {
      "name": "step",
      "description": "Step prop",
      "type": "number",
      "required": false,
      "defaultValue": 1
    },
    {
      "name": "disabled",
      "description": "Disabled state",
      "type": "boolean",
      "required": false,
      "defaultValue": false
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "h-2",
      "w-full",
      "cursor-pointer",
      "appearance-none",
      "rounded-full",
      "bg-secondary",
      "accent-primary"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(h-|rounded)",
        "pattern": "^(h-|rounded)"
      },
      {
        "description": "Do not override styles matching pattern ^(bg|accent)-(primary|secondary)",
        "pattern": "^(bg|accent)-(primary|secondary)"
      }
    ]
  },
  "aiPrompt": "Use Slider from @/components/starter. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "slider",
      "range",
      "form",
      "input"
    ],
    "category": "form",
    "status": "stable"
  }
}
