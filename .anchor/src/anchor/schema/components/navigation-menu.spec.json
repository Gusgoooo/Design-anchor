{
  "id": "navigation-menu",
  "componentName": "NavigationMenu",
  "version": "1.0.0",
  "intent": "Top navigation menu supporting simple link lists or complex dropdown panel navigation.",
  "wraps": {
    "module": "@/components/starter/navigation-menu",
    "primitives": [
      "NavigationMenu",
      "NavigationMenuList",
      "NavigationMenuItem",
      "NavigationMenuContent",
      "NavigationMenuTrigger",
      "NavigationMenuLink",
      "NavigationMenuIndicator",
      "NavigationMenuViewport"
    ]
  },
  "requiredProps": [
    {
      "name": "children",
      "description": "Children content",
      "type": "React.ReactNode",
      "required": true
    }
  ],
  "styleLock": {
    "baselineTokens": [
      "relative",
      "z-10",
      "flex",
      "max-w-max",
      "flex-1",
      "items-center",
      "justify-center"
    ],
    "blacklist": [
      {
        "description": "Do not override styles matching pattern ^(flex|grid|gap-|items-|justify-)",
        "pattern": "^(flex|grid|gap-|items-|justify-)"
      }
    ]
  },
  "aiPrompt": "Use NavigationMenu from @/components/starter. Use semantic props for variant and size. Do not hardcode colors or spacing. Colors must use design token classes only.",
  "meta": {
    "tags": [
      "navigation-menu",
      "navigation"
    ],
    "category": "navigation",
    "status": "stable"
  }
}
